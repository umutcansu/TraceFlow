{
  "name": "traceflow-rn-app",
  "version": "0.0.0",
  "private": true,
  "description": "Real Expo/React Native demo for TraceFlow. Builds a Metro bundle that proves the babel-plugin output survives Metro's modules-commonjs pass and the runtime works with RN's fetch/OkHttp stack. Use the simulator at ../rn-sample for fast Node-only checks.",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "bundle": "expo export --platform android --output-dir dist",
    "verify-metro": "node verify-metro.mjs"
  },
  "dependencies": {
    "expo": "^54.0.0",
    "expo-status-bar": "~2.2.0",
    "react": "19.1.0",
    "react-native": "0.81.0",
    "@umutcansu/traceflow-runtime": "^0.2.1"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@types/react": "~19.1.0",
    "typescript": "~5.8.0",
    "@umutcansu/traceflow-babel-plugin": "^0.1.1"
  }
}
