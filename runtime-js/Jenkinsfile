// Jenkins pipeline for publishing @umutcansu/traceflow-runtime to npm.
//
// Expected Jenkins setup
// ----------------------
// 1. A credential of type "Secret text" with ID:  npm-token-traceflow
//    containing a granular access token that has read+write permissions
//    on the @umutcansu scope (or at least the traceflow-runtime package).
//    Generate it at: https://www.npmjs.com/settings/umutcansu/tokens
//    Using a granular / automation token bypasses the interactive 2FA
//    prompt that blocks regular `npm publish`.
//
// 2. A NodeJS tool named "node20" installed via Manage Jenkins -> Tools.
//    (You can rename it; just update the `tools` block below accordingly.)
//    Alternative: uncomment the `agent { docker ... }` line and delete
//    the `tools` block to run inside a throwaway node:20 container.
//
// 3. An SCM checkout configured to track this repository. The pipeline
//    assumes `runtime-js/` is a subdirectory.
//
// How to trigger
// --------------
// Either:
//   - "Build with Parameters" in the Jenkins UI, pick a BUMP level
//     (none/patch/minor/major), and let the pipeline bump the version
//     in package.json, tag, push, and publish.
//   - Push a git tag matching `runtime-js-v*`; a tag trigger (configure
//     in the job) fires the pipeline with BUMP=none.
//
// Safety
// ------
// - Dry-run publish always runs before the real one; failures short-circuit
//   before anything hits the registry.
// - The pipeline refuses to publish a version that already exists on npm.
// - Git tag + commit are pushed *after* `npm publish` succeeds, so a
//   registry failure never leaves an orphan tag.
//
pipeline {
  agent any
  // agent { docker { image 'node:20-alpine'; args '-u root:root' } }

  tools {
    nodejs 'node20'
  }

  parameters {
    choice(
      name: 'BUMP',
      choices: ['none', 'patch', 'minor', 'major'],
      description: 'Semver bump applied to runtime-js/package.json before publish. "none" publishes the version that is already committed.'
    )
    booleanParam(
      name: 'DRY_RUN',
      defaultValue: false,
      description: 'Run through every step but skip the real `npm publish`.'
    )
  }

  environment {
    // npm reads NODE_AUTH_TOKEN from actions/setup-node style flows, but
    // for a direct CLI we write an ~/.npmrc below — the env var mirrors
    // the token for any sub-process that checks it.
    NPM_TOKEN = credentials('npm-token-traceflow')
  }

  options {
    timestamps()
    ansiColor('xterm')
    disableConcurrentBuilds()
    timeout(time: 20, unit: 'MINUTES')
  }

  stages {
    stage('Prepare workspace') {
      steps {
        sh '''
          set -eu
          node --version
          npm --version
          echo "Building from branch: ${GIT_BRANCH:-unknown}"
        '''
      }
    }

    stage('Install') {
      steps {
        dir('runtime-js') {
          sh 'npm ci --no-audit --no-fund'
        }
      }
    }

    stage('Typecheck') {
      steps {
        dir('runtime-js') {
          sh 'npm run typecheck'
        }
      }
    }

    stage('Build') {
      steps {
        dir('runtime-js') {
          sh 'npm run build'
          sh 'ls -la dist/'
        }
      }
    }

    stage('Bump version') {
      when { expression { params.BUMP != 'none' } }
      steps {
        dir('runtime-js') {
          sh '''
            set -eu
            # Configure git identity for the tag commit. Override via Jenkins
            # env vars if you want a different committer.
            git config user.email "${GIT_COMMITTER_EMAIL:-ci@traceflow.dev}"
            git config user.name  "${GIT_COMMITTER_NAME:-TraceFlow CI}"
            # npm version mutates package.json + package-lock.json and
            # creates a "vX.Y.Z" tag. We use a custom tag prefix so the
            # tag does not collide with Android/studio-plugin releases.
            NEW_VERSION=$(npm --no-git-tag-version version "${BUMP}")
            echo "Bumped to ${NEW_VERSION}"
            git add package.json package-lock.json
            git commit -m "runtime-js: release ${NEW_VERSION}"
            git tag "runtime-js-${NEW_VERSION}"
          '''
        }
      }
    }

    stage('Verify version is unpublished') {
      steps {
        dir('runtime-js') {
          sh '''
            set -eu
            NAME=$(node -p "require('./package.json').name")
            VERSION=$(node -p "require('./package.json').version")
            echo "Package: ${NAME}@${VERSION}"
            # `npm view` prints the matched versions; the string contains
            # the version exactly when it is already published. Fail fast
            # so the pipeline does not attempt an impossible republish.
            if npm view "${NAME}@${VERSION}" version 2>/dev/null | grep -qx "${VERSION}"; then
              echo "ERROR: ${NAME}@${VERSION} is already published. Bump the version first."
              exit 1
            fi
            echo "OK: version is unpublished."
          '''
        }
      }
    }

    stage('Publish (dry-run)') {
      steps {
        dir('runtime-js') {
          // Always run a dry-run before the real publish so we catch
          // registry / permission issues without producing a ghost version.
          sh '''
            set -eu
            # Scoped npmrc so we do not taint the Jenkins user's global config.
            echo "//registry.npmjs.org/:_authToken=${NPM_TOKEN}" > .npmrc
            npm publish --access public --dry-run
          '''
        }
      }
    }

    stage('Publish') {
      when { expression { !params.DRY_RUN } }
      steps {
        dir('runtime-js') {
          sh '''
            set -eu
            npm publish --access public
          '''
        }
      }
    }

    stage('Push tag') {
      when {
        allOf {
          expression { params.BUMP != 'none' }
          expression { !params.DRY_RUN }
        }
      }
      steps {
        sh '''
          set -eu
          # Push the bump commit and the runtime-js-vX.Y.Z tag back to origin.
          # Relies on the SCM checkout having push credentials — if yours
          # does not, replace this with an `sshagent` or `withCredentials`
          # block using a git credential.
          git push origin HEAD:${GIT_BRANCH#origin/}
          git push origin --tags
        '''
      }
    }
  }

  post {
    always {
      dir('runtime-js') {
        // Never leave the token on disk.
        sh 'rm -f .npmrc'
      }
    }
    success {
      echo "Done. If this was a real publish, the package is live on the npm registry."
    }
    failure {
      echo "Publish failed — check the stage logs. No tag was pushed."
    }
  }
}
